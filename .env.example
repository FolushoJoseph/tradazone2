# ─── EmailJS ───────────────────────────────────────────────────────────────────
# Sign up at https://www.emailjs.com/ — free tier allows 200 emails/month.
# Create a service, two email templates (invoice + receipt), then fill in below.
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# Template used for: send invoice to customer + confirmation copy to sender
VITE_EMAILJS_TEMPLATE_INVOICE=template_xxxxxxx

# Template used for: payment received (merchant) + receipt (customer)
VITE_EMAILJS_TEMPLATE_RECEIPT=template_xxxxxxx

# ─── Blockchain RPC endpoints (optional — public defaults are used if omitted) ─
# Override with Alchemy/Infura/private node for higher rate limits or testnet.
# VITE_ETH_RPC=https://eth.llamarpc.com
# VITE_STARKNET_RPC=https://free-rpc.nethermind.io/mainnet-juno
# VITE_STELLAR_HORIZON=https://horizon.stellar.org

# ─── Testnet overrides (uncomment for local testing) ──────────────────────────
# VITE_ETH_RPC=https://rpc.sepolia.org
# VITE_STARKNET_RPC=https://free-rpc.nethermind.io/sepolia-juno
# VITE_STELLAR_HORIZON=https://horizon-testnet.stellar.org

# ─── (existing) API base ──────────────────────────────────────────────────────
# Not used in live app — stub only
# VITE_API_URL=http://localhost:3000/api
